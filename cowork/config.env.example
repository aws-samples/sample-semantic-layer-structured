# Copy to ~/.cowork-semantic-layer/config.env (chmod 600) — or let
# ./setup-cognito.sh write it for you from the deployed CloudFormation outputs.
#
# COGNITO public PKCE client (no client_secret). These are the deployed
# semantic-layer-dev values; re-derive them any time with:
#   aws cloudformation describe-stacks --stack-name semantic-layer-dev-auth \
#     --query "Stacks[0].Outputs"
#
# NOTE: no `offline_access` scope — that is Entra-only. Cognito returns a
# refresh_token for the authorization_code grant automatically, and listing
# offline_access would fail with invalid_scope.
AUTHORIZE_URL="https://semantic-layer-dev-<ACCOUNT_ID>.auth.us-east-1.amazoncognito.com/oauth2/authorize"
TOKEN_URL="https://semantic-layer-dev-<ACCOUNT_ID>.auth.us-east-1.amazoncognito.com/oauth2/token"
CLIENT_ID="<MCP_PKCE_CLIENT_ID>"
GATEWAY_URL="https://semantic-layer-dev-mcp-gateway-<ID>.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp"
SCOPES="openid profile email semantic-layer-mcp/invoke"
# Loopback redirect already registered on the MCP PKCE client (bare, no path).
REDIRECT_URI="http://127.0.0.1:33418"
