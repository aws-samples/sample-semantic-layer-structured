AWS_PROFILE="XXX"
AWS_DEFAULT_REGION="us-east-1"
AWS_REGION="us-east-1"
PROJECT_NAME = 'semantic-layer'
KNOWLEDGE_BASE_ID="XXX"
ARTIFACTS_BUCKET="XXX"
NEPTUNE_GATEWAY_URL="XXX"
NEPTUNE_LOAD_ROLE="XXX"
ONTOLOGY_METADATA_TABLE="XXX"
ATHENA_WORKGROUP="XXX"
SEMANTIC_RAG_KB_ID="XXX"
SEMANTIC_RAG_DATA_SOURCE_ID="XXX"
S3T_CATALOG="s3tablescatalog/semantic-layer-analytics-tables"
S3T_DATABASE="normalized"
DYNAMODB_CATALOG="dynamodb_catalog"
DYNAMODB_DATABASE="default"
MAX_TABLES=0
MAX_ROWS=0

# Reuse an existing completed raw-DynamoDB SemanticRAG layer for nb7 Run A
# so we reuse it rather than rebuild. Unset/blank => nb7 builds a fresh raw layer.
RAW_DYNAMODB_LAYER_ID=semantic-rag-raw-dynamodb-2f3773a8

# Reuse an existing completed without-ontology layer for nb8 Run A
WITHOUT_ONTOLOGYRAG_LAYER_ID=
REUSE_EXISTING_LAYER=true
CONFIRM_DESTRUCTIVE_KB_WIPE=true